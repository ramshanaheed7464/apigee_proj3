{#
/**
 * @file
 * Template for the 'Breadcrumbs: Page title' block.
 */
#}

{% embed '@apigee-kickstart/block/block.twig' with {
  html_tag: 'li',
  block_utility_classes: [
    'breadcrumb-item',
    'active'
  ]
} %}
  {% block content %}
    {{ content['#title'] }}
  {% endblock %}
{% endembed %}
