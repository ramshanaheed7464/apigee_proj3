{
    "name": "drupal/apigee_edge",
    "license": "GPL-2.0-or-later",
    "type": "drupal-module",
    "description": "Apigee for Drupal.",
    "require": {
        "php": "~8.3.0",
        "ext-json": "*",
        "apigee/apigee-client-php": "~4.0.5",
        "drupal/core": "^11.3",
        "drupal/entity": "^1.0",
        "drupal/key": "^1.8",
        "php-http/guzzle7-adapter": "^1.0"
    },
    "require-dev": {
        "apigee/apigee-mock-client-php": "^1.1.3",
        "drupal/drupal-extension": "~5",
        "cweagans/composer-patches": "^1.6",
        "drupal/core-dev": "^11.3",
        "drush/drush": "^13.3",
        "mglaman/drupal-check": "1.5",
        "phpmd/phpmd": "^2.8.2",
        "phpmetrics/phpmetrics": "^2.5",
        "phpstan/phpstan": "^1.12"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "drush": {
            "services": {
                "drush.services.yml": "^13"
            }
        }
    }
}
